{
  "name": "poyo-local-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.14"
  },
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "bun --bun vite build",
    "start": "HOST=127.0.0.1 bun ./build/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "bun test",
    "test:e2e": "bun scripts/test-e2e-placeholder.ts",
    "validate:registry": "bun scripts/validate-registry.ts",
    "registry:validate": "bun run validate:registry",
    "registry:audit:network": "bun scripts/audit-registry-network.ts",
    "test:production-smoke": "bun scripts/production-smoke.ts",
    "test:smoke": "bun run test:production-smoke"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@sveltejs/kit": "2.69.3",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@types/bun": "1.3.14",
    "@unocss/extractor-svelte": "66.7.5",
    "@unocss/preset-wind4": "66.7.5",
    "@unocss/vite": "66.7.5",
    "svelte": "5.56.5",
    "svelte-adapter-bun": "1.0.1",
    "svelte-check": "4.7.2",
    "typescript": "5.9.3",
    "unocss": "66.7.5",
    "vite": "8.1.4"
  },
  "dependencies": {
    "bits-ui": "2.18.1"
  }
}
