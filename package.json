{
  "name": "poyo-local-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": "1.3.14"
  },
  "scripts": {
    "dev": "bun --bun vite dev --host 127.0.0.1",
    "build": "bun --bun vite build",
    "start": "bun scripts/start.ts",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "bun test tests/unit tests/integration tests/reliability tests/security/static-architecture.test.ts tests/performance",
    "test:e2e": "bun scripts/test-browser.ts e2e",
    "test:restart": "bun test --max-concurrency 1 tests/reliability/restart-recovery.test.ts",
    "test:security": "bun scripts/test-browser.ts security",
    "test:performance": "bun test --max-concurrency 1 tests/performance",
    "test:media-tools": "bun scripts/test-media-tools.ts",
    "test:live": "bun test --max-concurrency 1 ./tests/live/poyo-live.live.ts",
    "validate:registry": "bun scripts/validate-registry.ts",
    "registry:validate": "bun run validate:registry",
    "registry:audit:network": "bun scripts/audit-registry-network.ts",
    "registry:evidence:refresh": "bun scripts/refresh-registry-sources.ts && bun scripts/refresh-registry-fixtures.ts",
    "test:production-smoke": "bun scripts/production-smoke.ts",
    "test:smoke": "bun run test:production-smoke"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@sveltejs/kit": "2.69.3",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@types/bun": "1.3.14",
    "@unocss/extractor-svelte": "66.7.5",
    "@unocss/preset-wind4": "66.7.5",
    "@unocss/vite": "66.7.5",
    "axe-core": "^4.12.1",
    "playwright": "^1.61.1",
    "svelte": "5.56.5",
    "svelte-adapter-bun": "1.0.1",
    "svelte-check": "4.7.2",
    "typescript": "5.9.3",
    "unocss": "66.7.5",
    "vite": "8.1.4"
  },
  "dependencies": {
    "bits-ui": "2.18.1"
  }
}
