# Poyo credentials are read only by the local SvelteKit server.
POYO_API_KEY=

# The production server remains loopback-only unless deliberately changed.
HOST=127.0.0.1
PORT=3000

# Optional local storage overrides. Leave empty to use <repository>/data.
# PLS_APP_DATA_DIR replaces the root selected in onboarding/Settings and disables in-app moves.
# The narrower overrides remain authoritative for their individual locations.
# PLS_APP_DATA_DIR=
# PLS_DATABASE_PATH=
# PLS_MEDIA_DIR=
# PLS_LOG_DIR=

# Optional bounded JSONL log rotation settings.
PLS_LOG_SEPARATE_ERRORS=true
PLS_LOG_MAX_BYTES=5242880
PLS_LOG_MAX_AGE_MS=86400000
PLS_LOG_RETENTION_AGE_MS=1209600000
PLS_LOG_MAX_FILES=10
